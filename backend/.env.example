# ─────────────────────────────────────────────────────────────
# EL'druin Intelligence Platform — Configuration Template
# Copy this file to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-32-char-random-string

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Anonymisation
ANONYMIZATION_SALT=change-me-in-production-anon-salt

# ─── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://eldruin:password@localhost:5432/eldruin
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eldruin
POSTGRES_USER=eldruin
POSTGRES_PASSWORD=password

# ─── Neo4j ────────────────────────────────────────────────────
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=eldruin.events
KAFKA_TOPIC_PREDICTIONS=eldruin.predictions
KAFKA_GROUP_ID=eldruin-consumer

# ─── Pinecone (optional) ──────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=eldruin-embeddings

# ─── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ─── WorldMonitor Integration (optional) ──────────────────────
WORLDMONITOR_API_URL=https://api.worldmonitor.example.com
WORLDMONITOR_API_KEY=your-worldmonitor-api-key

# ─── MiroFish Integration (optional) ──────────────────────────
MIROFISH_API_URL=https://api.mirofish.example.com
MIROFISH_API_KEY=your-mirofish-api-key

# ─── Feature Flags ────────────────────────────────────────────
ENABLE_KAFKA_STREAMING=false
ENABLE_PINECONE=false
ENABLE_NEO4J=true
ENABLE_MULTIMODAL=false
