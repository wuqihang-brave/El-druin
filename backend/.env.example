# ────────────────────────────────────────────────────────────
# EL'druin Backend – Environment Variables
# Copy this file to backend/.env and fill in your values.
# The root .env.example is the canonical reference; this file
# exists for backend-only deployments.
# ────────────────────────────────────────────────────────────

# ── LLM provider (openai | groq | none) ──────────────────────
LLM_PROVIDER=none
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# ── LLM kill-switch ───────────────────────────────────────────
# Set to false to skip all LLM calls and rely on rule-based
# extraction only.  Useful when the API key returns 403 errors.
# Default: true
LLM_ENABLED=true

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Groq (required when LLM_PROVIDER=groq)
# IMPORTANT: your key must have access to the chat/completions
# endpoint. Not all free-tier keys do — if you see 403 errors,
# set LLM_ENABLED=false to use rule-based extraction instead.
#
# Supported models:
#   llama3-8b-8192        (fast, low token cost)
#   llama3-70b-8192       (higher quality)
#   mixtral-8x7b-32768    (long context)
GROQ_API_KEY=

# ── Graph database ────────────────────────────────────────────
GRAPH_BACKEND=kuzu
KUZU_DB_PATH=./data/kuzu_db
KUZU_KG_PATH=./data/el_druin.kuzu

# ── News / feeds ──────────────────────────────────────────────
NEWSAPI_KEY=
NEWS_INGEST_INTERVAL_MINUTES=30

# ── FastAPI server ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
DEBUG=false
