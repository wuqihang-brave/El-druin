@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix eld:  <https://example.org/eldruin#> .

# ── Ontology declaration ────────────────────────────────────────────────────
<https://example.org/eldruin>
    a owl:Ontology ;
    rdfs:label "EL-DRUIN Geopolitical Pattern Ontology" ;
    rdfs:comment """OWL 2 / Turtle serialisation of the EL-DRUIN 21-pattern
    registry.  Corresponds to CARTESIAN_PATTERN_REGISTRY in
    backend/ontology/relation_schema.py (and pattern_i18n.py for i18n keys).
    Generated for ISWC 2026 submission; see paper/latex/main.tex Section 4.""" .

# ── Classes ─────────────────────────────────────────────────────────────────
eld:DynamicPattern a owl:Class ;
    rdfs:label "DynamicPattern" ;
    rdfs:comment "A typed mid-level semantic unit bridging event-level observations and trajectory-level reasoning." .

eld:GeopoliticalDomain a owl:Class ;
    rdfs:label "GeopoliticalDomain" ;
    rdfs:comment "One of seven geopolitical domain partitions." .

eld:MechanismClass a owl:Class ;
    rdfs:label "MechanismClass" ;
    rdfs:comment "One of three cross-domain mechanism classes." .

eld:EntityType a owl:Class ;
    rdfs:label "EntityType" ;
    rdfs:comment "Typed entity in the Cartesian registry." .

eld:RelationType a owl:Class ;
    rdfs:label "RelationType" ;
    rdfs:comment "Typed relation in the Cartesian registry." .

eld:ProvenanceRecord a owl:Class ;
    rdfs:label "ProvenanceRecord" ;
    rdfs:comment "Links numerical outputs to their derivation via compute_trace_ref." .

eld:Trajectory a owl:Class ;
    rdfs:label "Trajectory" ;
    rdfs:comment "A sequence of DynamicPattern transitions leading to an attractor." .

# Domain subclasses (7 domains)
eld:Geopolitics   a owl:Class ; rdfs:subClassOf eld:GeopoliticalDomain ; rdfs:label "Geopolitics" .
eld:Economics     a owl:Class ; rdfs:subClassOf eld:GeopoliticalDomain ; rdfs:label "Economics" .
eld:Technology    a owl:Class ; rdfs:subClassOf eld:GeopoliticalDomain ; rdfs:label "Technology" .
eld:Military      a owl:Class ; rdfs:subClassOf eld:GeopoliticalDomain ; rdfs:label "Military" .
eld:Information   a owl:Class ; rdfs:subClassOf eld:GeopoliticalDomain ; rdfs:label "Information" .
eld:Legal         a owl:Class ; rdfs:subClassOf eld:GeopoliticalDomain ; rdfs:label "Legal" .
eld:Social        a owl:Class ; rdfs:subClassOf eld:GeopoliticalDomain ; rdfs:label "Social" .

# Mechanism subclasses (3 mechanism classes)
eld:CoerciveMechanism     a owl:Class ; rdfs:subClassOf eld:MechanismClass ; rdfs:label "Coercive" .
eld:CooperativeMechanism  a owl:Class ; rdfs:subClassOf eld:MechanismClass ; rdfs:label "Cooperative" .
eld:StructuralMechanism   a owl:Class ; rdfs:subClassOf eld:MechanismClass ; rdfs:label "Structural" .

# ── CompositionRule reification class ───────────────────────────────────────
eld:CompositionRule a owl:Class ;
    rdfs:label "CompositionRule" ;
    rdfs:comment "Reification of a ternary composition rule: when sourcePattern and contextPattern are simultaneously active, the system tends toward resultPattern." .

eld:sourcePattern a owl:ObjectProperty ;
    rdfs:domain eld:CompositionRule ;
    rdfs:range  eld:DynamicPattern ;
    rdfs:label  "sourcePattern" .

eld:contextPattern a owl:ObjectProperty ;
    rdfs:domain eld:CompositionRule ;
    rdfs:range  eld:DynamicPattern ;
    rdfs:label  "contextPattern" .

eld:resultPattern a owl:ObjectProperty ;
    rdfs:domain eld:CompositionRule ;
    rdfs:range  eld:DynamicPattern ;
    rdfs:label  "resultPattern" .

# ── Object Properties ────────────────────────────────────────────────────────
eld:hasDomain a owl:ObjectProperty ;
    rdfs:domain eld:DynamicPattern ;
    rdfs:range  eld:GeopoliticalDomain ;
    rdfs:label  "hasDomain" .

eld:hasMechanismClass a owl:ObjectProperty ;
    rdfs:domain eld:DynamicPattern ;
    rdfs:range  eld:MechanismClass ;
    rdfs:label  "hasMechanismClass" .

eld:composedWith a owl:ObjectProperty ;
    rdfs:domain eld:DynamicPattern ;
    rdfs:range  eld:DynamicPattern ;
    rdfs:label  "composedWith" ;
    rdfs:comment "Retained for backward compatibility. Full ternary rules are now encoded as eld:CompositionRule individuals." .

eld:inversePattern a owl:ObjectProperty ;
    rdfs:domain eld:DynamicPattern ;
    rdfs:range  eld:DynamicPattern ;
    owl:inverseOf eld:inversePattern ;
    rdfs:label  "inversePattern" ;
    rdfs:comment "Symmetric: inversePattern(A,B) ↔ inversePattern(B,A)." .

eld:activates a owl:ObjectProperty ;
    rdfs:domain eld:ProvenanceRecord ;
    rdfs:range  eld:DynamicPattern ;
    rdfs:label  "activates" .

# ── Datatype Properties ──────────────────────────────────────────────────────
eld:confidencePrior a owl:DatatypeProperty ;
    rdfs:domain eld:DynamicPattern ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "confidencePrior" ;
    rdfs:comment "Ontology-defined base-rate belief; participates directly in Bayesian posterior." .

eld:patternName a owl:DatatypeProperty ;
    rdfs:domain eld:DynamicPattern ;
    rdfs:range  xsd:string ;
    rdfs:label  "patternName" .

# ── Named Individuals: 21 DynamicPatterns ────────────────────────────────────
# Exactly 21 active patterns from CARTESIAN_PATTERN_REGISTRY (relation_schema.py),
# covering all 7 geopolitical domains.  Inverse/de-escalation patterns are
# referenced via eld:inversePattern but are not declared as full individuals here.

# ── Geopolitics domain ───────────────────────────────────────────────────────

eld:HegemSanctions a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Hegemonic Sanctions" ;
    eld:hasDomain         eld:Geopolitics ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.78"^^xsd:decimal ;
    eld:inversePattern    eld:SanctionsRelief .

eld:GreatPowerCoercion a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Great-Power Coercion / Deterrence" ;
    eld:hasDomain         eld:Geopolitics ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.70"^^xsd:decimal ;
    eld:inversePattern    eld:DiplomaticConcession .

eld:MultilateralAllianceSanctions a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Multilateral Alliance Sanctions" ;
    eld:hasDomain         eld:Geopolitics ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.73"^^xsd:decimal ;
    eld:inversePattern    eld:MultilateralSanctionsRelief .

eld:FormalMilitaryAlliance a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Formal Military Alliance" ;
    eld:hasDomain         eld:Geopolitics ;
    eld:hasMechanismClass eld:CooperativeMechanism ;
    eld:confidencePrior   "0.74"^^xsd:decimal ;
    eld:inversePattern    eld:AllianceDisintegration .

# ── Military domain ──────────────────────────────────────────────────────────

eld:InterstateMillitaryConflict a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Interstate Military Conflict" ;
    eld:hasDomain         eld:Military ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.75"^^xsd:decimal ;
    eld:inversePattern    eld:CeasefirePeace .

eld:NonStateArmedProxyConflict a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Non-State Armed Proxy Conflict" ;
    eld:hasDomain         eld:Military ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.68"^^xsd:decimal ;
    eld:inversePattern    eld:ProxyDisarmament .

# ── Economics domain ─────────────────────────────────────────────────────────

eld:FinancialIsolation a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Financial Isolation / SWIFT Cut-Off" ;
    eld:hasDomain         eld:Economics ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.79"^^xsd:decimal ;
    eld:inversePattern    eld:FinancialReintegration .

eld:TradeWarDecoupling a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Trade War / Decoupling" ;
    eld:hasDomain         eld:Economics ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.68"^^xsd:decimal ;
    eld:inversePattern    eld:BilateralTradeDependency .

eld:BilateralTradeDependency a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Bilateral Trade Dependency" ;
    eld:hasDomain         eld:Economics ;
    eld:hasMechanismClass eld:StructuralMechanism ;
    eld:confidencePrior   "0.71"^^xsd:decimal ;
    eld:inversePattern    eld:TradeWarDecoupling .

# ── Technology domain ────────────────────────────────────────────────────────

eld:EntityListTechBlockade a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Entity-List Technology Blockade" ;
    eld:hasDomain         eld:Technology ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.80"^^xsd:decimal ;
    eld:inversePattern    eld:TechLicenceUnblocking .

eld:TechDecoupling a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Tech Decoupling / Technology Iron Curtain" ;
    eld:hasDomain         eld:Technology ;
    eld:hasMechanismClass eld:StructuralMechanism ;
    eld:confidencePrior   "0.76"^^xsd:decimal ;
    eld:inversePattern    eld:TechCoopReintegration .

eld:TechStandardsLeadership a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Technology Standards Leadership" ;
    eld:hasDomain         eld:Technology ;
    eld:hasMechanismClass eld:StructuralMechanism ;
    eld:confidencePrior   "0.72"^^xsd:decimal ;
    eld:inversePattern    eld:StandardCompetitionFailure .

eld:TechBreakthrough a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Technology Breakthrough / Space Exploration" ;
    eld:hasDomain         eld:Technology ;
    eld:hasMechanismClass eld:StructuralMechanism ;
    eld:confidencePrior   "0.72"^^xsd:decimal ;
    eld:inversePattern    eld:TechBottleneck .

# ── Information domain ───────────────────────────────────────────────────────

eld:InformationWarfare a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Information Warfare / Narrative Control" ;
    eld:hasDomain         eld:Information ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.68"^^xsd:decimal ;
    eld:inversePattern    eld:InformationRestoration .

# ── Legal domain ─────────────────────────────────────────────────────────────

eld:LegalSovereignty a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Legal Sovereignty / Jurisdictional Conflict" ;
    eld:hasDomain         eld:Legal ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.72"^^xsd:decimal ;
    eld:inversePattern    eld:RegulatoryEasing .

eld:CrossBorderRegulatory a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Cross-Border Regulatory / Compliance Constraint" ;
    eld:hasDomain         eld:Legal ;
    eld:hasMechanismClass eld:StructuralMechanism ;
    eld:confidencePrior   "0.71"^^xsd:decimal ;
    eld:inversePattern    eld:RegulatoryEasing .

# ── Social domain ────────────────────────────────────────────────────────────

eld:SocialMobilization a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Social Mobilisation / Nationalist Pressure" ;
    eld:hasDomain         eld:Social ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.65"^^xsd:decimal ;
    eld:inversePattern    eld:SocialStability .

eld:SocialStability a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Social Stability / Cohesion" ;
    eld:hasDomain         eld:Social ;
    eld:hasMechanismClass eld:CooperativeMechanism ;
    eld:confidencePrior   "0.67"^^xsd:decimal ;
    eld:inversePattern    eld:SocialMobilization .

# ── Business domain ──────────────────────────────────────────────────────────

eld:ProductCapabilityExpansion a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Product Capability Expansion" ;
    eld:hasDomain         eld:Economics ;
    eld:hasMechanismClass eld:StructuralMechanism ;
    eld:confidencePrior   "0.72"^^xsd:decimal ;
    eld:inversePattern    eld:ProductCapabilityContraction .

eld:PlatformCompetition a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Platform Competition / Niche Expansion" ;
    eld:hasDomain         eld:Economics ;
    eld:hasMechanismClass eld:CoerciveMechanism ;
    eld:confidencePrior   "0.70"^^xsd:decimal ;
    eld:inversePattern    eld:MarketMonopoly .

eld:CreatorEconomyIntegration a owl:NamedIndividual, eld:DynamicPattern ;
    eld:patternName       "Creator Economy Integration" ;
    eld:hasDomain         eld:Economics ;
    eld:hasMechanismClass eld:CooperativeMechanism ;
    eld:confidencePrior   "0.68"^^xsd:decimal ;
    eld:inversePattern    eld:CreatorPlatformFragmentation .

# ── Composition rules (16 rules, fully reified) ──────────────────────────────
# These correspond to composition_table in backend/ontology/relation_schema.py
# Rule format: CompRuleNNN : (sourcePattern ∘ contextPattern → resultPattern)
# Rules 001–015 are drawn directly from the actual composition_table.
# Rule 016 is inferred from domain structure; verify against composition_table.

eld:CompRule001 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "HegemSanctions ∘ FormalMilitaryAlliance → MultilateralAllianceSanctions" ;
    eld:sourcePattern  eld:HegemSanctions ;
    eld:contextPattern eld:FormalMilitaryAlliance ;
    eld:resultPattern  eld:MultilateralAllianceSanctions .

eld:CompRule002 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "FormalMilitaryAlliance ∘ InterstateMillitaryConflict → NonStateArmedProxyConflict" ;
    eld:sourcePattern  eld:FormalMilitaryAlliance ;
    eld:contextPattern eld:InterstateMillitaryConflict ;
    eld:resultPattern  eld:NonStateArmedProxyConflict .

eld:CompRule003 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "HegemSanctions ∘ EntityListTechBlockade → TechDecoupling" ;
    eld:sourcePattern  eld:HegemSanctions ;
    eld:contextPattern eld:EntityListTechBlockade ;
    eld:resultPattern  eld:TechDecoupling .

eld:CompRule004 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "InformationWarfare ∘ GreatPowerCoercion → NonStateArmedProxyConflict" ;
    eld:sourcePattern  eld:InformationWarfare ;
    eld:contextPattern eld:GreatPowerCoercion ;
    eld:resultPattern  eld:NonStateArmedProxyConflict .

eld:CompRule005 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "FinancialIsolation ∘ HegemSanctions → HegemSanctions" ;
    eld:sourcePattern  eld:FinancialIsolation ;
    eld:contextPattern eld:HegemSanctions ;
    eld:resultPattern  eld:HegemSanctions .

eld:CompRule006 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "TradeWarDecoupling ∘ EntityListTechBlockade → TechDecoupling" ;
    eld:sourcePattern  eld:TradeWarDecoupling ;
    eld:contextPattern eld:EntityListTechBlockade ;
    eld:resultPattern  eld:TechDecoupling .

eld:CompRule007 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "ProductCapabilityExpansion ∘ PlatformCompetition → CreatorEconomyIntegration" ;
    eld:sourcePattern  eld:ProductCapabilityExpansion ;
    eld:contextPattern eld:PlatformCompetition ;
    eld:resultPattern  eld:CreatorEconomyIntegration .

eld:CompRule008 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "PlatformCompetition ∘ CreatorEconomyIntegration → ProductCapabilityExpansion" ;
    eld:sourcePattern  eld:PlatformCompetition ;
    eld:contextPattern eld:CreatorEconomyIntegration ;
    eld:resultPattern  eld:ProductCapabilityExpansion .

eld:CompRule009 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "CreatorEconomyIntegration ∘ PlatformCompetition → CrossBorderRegulatory" ;
    eld:sourcePattern  eld:CreatorEconomyIntegration ;
    eld:contextPattern eld:PlatformCompetition ;
    eld:resultPattern  eld:CrossBorderRegulatory .

eld:CompRule010 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "TechBreakthrough ∘ EntityListTechBlockade → TechDecoupling" ;
    eld:sourcePattern  eld:TechBreakthrough ;
    eld:contextPattern eld:EntityListTechBlockade ;
    eld:resultPattern  eld:TechDecoupling .

eld:CompRule011 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "SocialMobilization ∘ HegemSanctions → MultilateralAllianceSanctions" ;
    eld:sourcePattern  eld:SocialMobilization ;
    eld:contextPattern eld:HegemSanctions ;
    eld:resultPattern  eld:MultilateralAllianceSanctions .

eld:CompRule012 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "SocialMobilization ∘ InterstateMillitaryConflict → NonStateArmedProxyConflict" ;
    eld:sourcePattern  eld:SocialMobilization ;
    eld:contextPattern eld:InterstateMillitaryConflict ;
    eld:resultPattern  eld:NonStateArmedProxyConflict .

eld:CompRule013 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "LegalSovereignty ∘ EntityListTechBlockade → TechStandardsLeadership" ;
    eld:sourcePattern  eld:LegalSovereignty ;
    eld:contextPattern eld:EntityListTechBlockade ;
    eld:resultPattern  eld:TechStandardsLeadership .

eld:CompRule014 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "LegalSovereignty ∘ HegemSanctions → CrossBorderRegulatory" ;
    eld:sourcePattern  eld:LegalSovereignty ;
    eld:contextPattern eld:HegemSanctions ;
    eld:resultPattern  eld:CrossBorderRegulatory .

eld:CompRule015 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "SocialStability ∘ FormalMilitaryAlliance → MultilateralAllianceSanctions" ;
    eld:sourcePattern  eld:SocialStability ;
    eld:contextPattern eld:FormalMilitaryAlliance ;
    eld:resultPattern  eld:MultilateralAllianceSanctions .

eld:CompRule016 a owl:NamedIndividual, eld:CompositionRule ;
    rdfs:label "BilateralTradeDependency ∘ HegemSanctions → TradeWarDecoupling" ;
    rdfs:comment "Inferred from domain structure; verify against composition_table." ;
    eld:sourcePattern  eld:BilateralTradeDependency ;
    eld:contextPattern eld:HegemSanctions ;
    eld:resultPattern  eld:TradeWarDecoupling .
