# ────────────────────────────────────────────────────────────
# EL'druin Intelligence Platform – Environment Variables
# Copy this file to .env and fill in your values.
# ────────────────────────────────────────────────────────────

# ── LLM provider (openai | groq | none) ──────────────────────
LLM_PROVIDER=none
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Groq (required when LLM_PROVIDER=groq)
GROQ_API_KEY=

# ── Graph database (kuzu | networkx) ─────────────────────────
GRAPH_BACKEND=kuzu
KUZU_DB_PATH=./data/kuzu_db

# Neo4j (optional, not yet implemented)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# ── News / feeds ─────────────────────────────────────────────
# Optional: comma-separated list of RSS feed URLs to override defaults
# RSS_FEED_URLS=https://feeds.reuters.com/reuters/worldNews,https://rss.nytimes.com/services/xml/rss/nyt/World.xml

# Optional: NewsAPI key
NEWSAPI_KEY=

# ── FastAPI server ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
DEBUG=false

# ── Streamlit frontend ────────────────────────────────────────
BACKEND_URL=http://localhost:8001/api/v1
